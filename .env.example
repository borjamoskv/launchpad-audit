# Token opcional para auditorías autenticadas desde /api/audit.
# Los endpoints públicos de badge/share no usan este token.
# Si tiene permisos privados, mantenlo solo en variables seguras del servidor.
GITHUB_TOKEN=

# OAuth opcional para "Conectar GitHub" desde la interfaz.
# Crea una GitHub OAuth App y apunta callback a:
# http://localhost:3000/api/auth/github/callback (local) o tu dominio en producción.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Si lo dejas vacío, la app derivará el callback automáticamente desde la URL actual.
GITHUB_OAUTH_REDIRECT_URI=
